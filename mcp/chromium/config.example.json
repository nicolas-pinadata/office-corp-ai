{
  "mcpServers": {
    "officecorp-chromium": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://127.0.0.1:9222",
        "--allowed-hosts",
        "127.0.0.1,localhost"
      ],
      "disabled": false
    }
  }
}
